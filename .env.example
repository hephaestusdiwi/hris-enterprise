# =========================================================
# HRIS Enterprise — Environment Reference (root level)
# =========================================================
# File ini baru berisi placeholder. Detail konfigurasi akan
# dilengkapi bertahap:
#   - APP_*      -> diisi lengkap di STEP 11 (Laravel Installation)
#   - DB_*       -> diisi lengkap di STEP 6 (PostgreSQL)
#   - REDIS_*    -> diisi lengkap di STEP 7 (Redis)
#   - QUEUE_*    -> diisi lengkap di STEP 8 (Queue)
# backend/.env.example dan frontend/.env.example yang sebenarnya
# akan dibuat masing-masing saat Laravel & Vue di-install.
# =========================================================

APP_NAME="HRIS Enterprise"
APP_ENV=local

# Diisi di STEP 6
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Diisi di STEP 7
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=
