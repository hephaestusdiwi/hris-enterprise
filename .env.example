# =========================================================
# HRIS Enterprise — Environment (root, dipakai docker-compose.yml)
# =========================================================
# Copy file ini jadi `.env` di root project, lalu isi sesuai kebutuhan.
# File ini HANYA dipakai untuk interpolasi docker-compose.yml (port, kredensial DB container).
# backend/.env (Laravel) dibuat terpisah di STEP 11 dan akan pakai
# DB_HOST=postgres & REDIS_HOST=redis (nama service container ini).
# =========================================================

# Port yang di-expose ke host machine (Windows/WSL2)
APP_PORT=8000
VITE_PORT=5173
DB_PORT=5432
REDIS_PORT=6379

# Kredensial PostgreSQL (dipakai container postgres & backend/.env nanti)
DB_DATABASE=hris
DB_USERNAME=hris
DB_PASSWORD=secret
REDIS_PASSWORD=secret
